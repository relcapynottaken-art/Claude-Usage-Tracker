{
  "manifest_version": 3,
  "name": "Claude Usage Tracker (local)",
  "version": "1.0.3",
  "description": "Shows your Claude session + weekly usage as two bars in the composer and an estimated token count in the header. Reads only your own usage data; nothing leaves your browser.",
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*", "https://*.claude.ai/*"],
  "action": {
    "default_title": "Claude Usage Tracker",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://*.claude.ai/*"],
      "js": ["src/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://claude.ai/*", "https://*.claude.ai/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ]
}
